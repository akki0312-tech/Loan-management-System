# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environment — Docker installs packages itself from requirements.txt
.venv/

# Local database — containers use PostgreSQL, not SQLite
db.sqlite3

# Git
.git/
.gitignore

# Environment files — injected at runtime, not baked into image
.env

# Media uploads — use a volume or cloud storage in production
media/

# Gunicorn config (we'll pass config differently)
gunicorn.conf.py